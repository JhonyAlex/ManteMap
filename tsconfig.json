{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@mantemap/database": ["./packages/database/src"],
      "@mantemap/ui": ["./packages/ui/src"],
      "@mantemap/validation": ["./packages/validation/src"],
      "@mantemap/shared": ["./packages/shared/src"],
      "@mantemap/config": ["./packages/config/src"]
    }
  },
  "exclude": ["node_modules", ".next", "dist", "coverage"]
}
