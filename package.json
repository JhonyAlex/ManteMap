{
  "name": "mantemap",
  "private": true,
  "version": "0.1.0",
  "description": "Plataforma de gestión documental, activos, vencimientos y planos interactivos",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:e2e": "turbo test:e2e",
    "db:migrate": "pnpm --filter @mantemap/database db:migrate",
    "db:push": "pnpm --filter @mantemap/database db:push",
    "db:studio": "pnpm --filter @mantemap/database db:studio",
    "db:seed": "pnpm --filter @mantemap/database db:seed",
    "db:generate": "pnpm --filter @mantemap/database db:generate",
    "clean": "turbo clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "turbo": "^2.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
