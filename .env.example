# ===========================================
# ManteMap — Variables de entorno
# ===========================================
# Copiar este archivo a .env y completar los valores.
# NO subir .env al repositorio.

# -------------------------------------------
# Base de datos
# -------------------------------------------
# URL de conexión a PostgreSQL.
# Formato: postgresql://USUARIO:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="postgresql://mantemap:mantemap@localhost:5432/mantemap"

# -------------------------------------------
# Autenticación
# -------------------------------------------
# Secret para NextAuth.js. Generar con: openssl rand -base64 32
AUTH_SECRET=""

# URL base de la aplicación (sin barra final)
APP_URL="http://localhost:3000"

# -------------------------------------------
# Almacenamiento de archivos
# -------------------------------------------
# Driver: "local" | "s3"
STORAGE_DRIVER="local"

# Ruta local para STORAGE_DRIVER=local
STORAGE_LOCAL_PATH="./storage"

# Configuración S3 (para STORAGE_DRIVER=s3)
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET="mantemap"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# -------------------------------------------
# Correo electrónico (opcional)
# -------------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@mantemap.local"

# -------------------------------------------
# Puerto de la aplicación
# -------------------------------------------
PORT=3000
