// ===========================================
// ManteMap — Prisma Schema
// ===========================================
// Phase 2 Slice 1 adds project-scoped item types.
// Production schema changes require the documented baseline procedure first.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------
// Autenticación (NextAuth.js)
// -------------------------------------------

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          UserRole   @default(TECHNICIAN)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts                         Account[]
  sessions                         Session[]
  projects                         ProjectMember[]
  ownedProjects                    Project[]
  uploadedDocs                     DocumentVersion[]
  notificationPreferences          NotificationPreference[]
  channelConfigs                   UserChannelConfig[]
  inspections                      Inspection[]
  assignedMaintenancePlanRevisions MaintenancePlanRevision[] @relation("MaintenancePlanRevisionAssignee")
  assignedWorkOrders               WorkOrder[]                @relation("WorkOrderAssignee")
  completedWorkOrderChecklistItems WorkOrderChecklistItem[]   @relation("WorkOrderChecklistCompletedBy")
  maintenanceGenerationRuns        MaintenanceGenerationRun[] @relation("MaintenanceGenerationRunActor")
  workOrderActivities              WorkOrderActivity[]        @relation("WorkOrderActivityActor")

  @@map("users")
}

enum UserRole {
  ADMIN
  PROJECT_MANAGER
  TECHNICIAN
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// -------------------------------------------
// Proyectos
// -------------------------------------------

model Project {
  id                               String        @id @default(cuid())
  code                             String        @unique
  name                             String
  description                      String?
  status                           ProjectStatus @default(ACTIVE)
  ownerId                          String
  image                            String?
  config                           Json?         @default("{}")
  timezone                         String        @default("Europe/Madrid")
  maintenanceGenerationHorizonDays Int           @default(90)
  createdAt                        DateTime      @default(now())
  updatedAt                        DateTime      @updatedAt

  owner                     User                       @relation(fields: [ownerId], references: [id])
  members                   ProjectMember[]
  itemTypes                 ItemType[]
  locations                 Location[]
  events                    Event[]
  alerts                    Alert[]
  notificationPreferences   NotificationPreference[]
  webhookEndpoints          WebhookEndpoint[]
  maintenancePlans          MaintenancePlan[]
  workOrders                WorkOrder[]
  maintenanceGenerationRuns MaintenanceGenerationRun[]

  @@index([ownerId])
  @@index([status])
  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model ProjectMember {
  id        String      @id @default(cuid())
  userId    String
  projectId String
  role      ProjectRole @default(MEMBER)
  createdAt DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_members")
}

model ItemType {
  id          String         @id @default(cuid())
  projectId   String
  name        String
  slug        String
  description String?
  icon        String?
  color       String?
  status      ItemTypeStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dynamicFields DynamicField[]
  statuses      Status[]
  items         Item[]

  @@unique([projectId, slug])
  @@index([projectId, status])
  @@index([projectId, name])
  @@map("item_types")
}

enum DynamicFieldType {
  SHORT_TEXT
  LONG_TEXT
  NUMBER
  DECIMAL
  CURRENCY
  BOOLEAN
  DATE
  DATETIME
  SELECT
  MULTI_SELECT
  URL
  EMAIL
  PHONE
  FILE
  IMAGE
  ITEM_RELATION
  LOCATION_RELATION
  USER_RELATION
}

model DynamicField {
  id           String           @id @default(cuid())
  itemTypeId   String
  name         String
  key          String
  type         DynamicFieldType
  description  String?
  required     Boolean          @default(false)
  defaultValue Json?
  order        Int              @default(0)
  visible      Boolean          @default(true)
  active       Boolean          @default(true)
  options      Json?
  unit         String?
  validation   Json?
  showInList   Boolean          @default(false)
  showInSearch Boolean          @default(false)
  helpText     String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  itemType ItemType @relation(fields: [itemTypeId], references: [id], onDelete: Cascade)

  itemFieldValues ItemFieldValue[]

  @@unique([itemTypeId, key])
  @@index([itemTypeId, order])
  @@map("dynamic_fields")
}

model Status {
  id          String   @id @default(cuid())
  itemTypeId  String
  name        String
  key         String
  color       String
  icon        String?
  description String?
  order       Int      @default(0)
  isDefault   Boolean  @default(false)
  active      Boolean  @default(true)
  isFinal     Boolean  @default(false)
  isBlocking  Boolean  @default(false)
  isIncident  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itemType ItemType @relation(fields: [itemTypeId], references: [id], onDelete: Cascade)
  items    Item[]

  @@unique([itemTypeId, key])
  @@index([itemTypeId, order])
  @@map("statuses")
}

model Item {
  id         String   @id @default(cuid())
  name       String
  slug       String
  itemTypeId String
  statusId   String?
  locationId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  itemType         ItemType          @relation(fields: [itemTypeId], references: [id], onDelete: Cascade)
  status           Status?           @relation(fields: [statusId], references: [id], onDelete: SetNull)
  location         Location?         @relation(fields: [locationId], references: [id], onDelete: SetNull)
  fieldValues      ItemFieldValue[]
  documents        Document[]
  events           Event[]
  markers          LocationMarker[]
  qrCode           ItemQRCode?
  inspections      Inspection[]
  maintenancePlans MaintenancePlan[]
  workOrders       WorkOrder[]

  @@unique([itemTypeId, slug])
  @@index([itemTypeId])
  @@index([statusId])
  @@index([locationId])
  @@map("items")
}

model ItemQRCode {
  id          String   @id @default(cuid())
  itemId      String   @unique
  storagePath String?
  createdAt   DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("item_qr_codes")
}

model ItemFieldValue {
  id             String   @id @default(cuid())
  itemId         String
  dynamicFieldId String
  value          Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  item         Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  dynamicField DynamicField @relation(fields: [dynamicFieldId], references: [id], onDelete: Cascade)

  @@unique([itemId, dynamicFieldId])
  @@index([itemId])
  @@index([dynamicFieldId])
  @@map("item_field_values")
}

enum ItemTypeStatus {
  ACTIVE
  ARCHIVED
}

enum ProjectRole {
  OWNER
  MANAGER
  MEMBER
  VIEWER
}

// -------------------------------------------
// Preventive Maintenance (persistence only)
// -------------------------------------------

enum MaintenanceScheduleKind {
  FIXED
  RRULE
}

enum WorkOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceGenerationTrigger {
  HOURLY
  BACKFILL
  DISCARD
  REGENERATION
}

enum MaintenanceGenerationStatus {
  STARTED
  COMPLETED
  FAILED
}

enum WorkOrderActivityAction {
  CREATED
  STARTED
  COMPLETED
  CANCELLED
  REPROGRAMMED
  BACKFILLED
  DISCARDED
}

model MaintenancePlan {
  id               String    @id @default(cuid())
  projectId        String
  itemId           String
  active           Boolean   @default(true)
  generationCursor DateTime? @db.Timestamptz
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project        Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  item           Item                       @relation(fields: [itemId], references: [id], onDelete: Restrict)
  revisions      MaintenancePlanRevision[]
  workOrders     WorkOrder[]
  generationRuns MaintenanceGenerationRun[]

  @@index([projectId, active])
  @@index([itemId])
  @@map("maintenance_plans")
}

model MaintenancePlanRevision {
  id                String                  @id @default(cuid())
  maintenancePlanId String
  effectiveFrom     DateTime                @db.Timestamptz
  title             String?
  description       String?
  scheduleKind      MaintenanceScheduleKind
  scheduledAt       DateTime?               @db.Timestamptz
  startsAt          DateTime?               @db.Timestamptz
  rrule             String?
  dueOffsetMinutes  Int?
  assigneeId        String?
  definition        Json?
  createdAt         DateTime                @default(now())

  maintenancePlan MaintenancePlan                @relation(fields: [maintenancePlanId], references: [id], onDelete: Cascade)
  assignee        User?                          @relation("MaintenancePlanRevisionAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  checklistItems  MaintenancePlanChecklistItem[]
  workOrders      WorkOrder[]

  @@unique([maintenancePlanId, effectiveFrom])
  @@index([maintenancePlanId, effectiveFrom])
  @@index([assigneeId])
  @@map("maintenance_plan_revisions")
}

model MaintenancePlanChecklistItem {
  id                        String   @id @default(cuid())
  maintenancePlanRevisionId String
  title                     String
  position                  Int
  required                  Boolean  @default(false)
  createdAt                 DateTime @default(now())

  maintenancePlanRevision MaintenancePlanRevision  @relation(fields: [maintenancePlanRevisionId], references: [id], onDelete: Cascade)
  workOrderChecklistItems WorkOrderChecklistItem[]

  @@unique([maintenancePlanRevisionId, position])
  @@map("maintenance_plan_checklist_items")
}

model WorkOrder {
  id                        String          @id @default(cuid())
  projectId                 String
  maintenancePlanId         String
  maintenancePlanRevisionId String
  itemId                    String
  assigneeId                String?
  occurrenceKey             String
  title                     String?
  description               String?
  definitionSnapshot        Json?
  scheduledAt               DateTime        @db.Timestamptz
  dueAt                     DateTime?       @db.Timestamptz
  status                    WorkOrderStatus @default(PENDING)
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  project                 Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  maintenancePlan         MaintenancePlan          @relation(fields: [maintenancePlanId], references: [id], onDelete: Restrict)
  maintenancePlanRevision MaintenancePlanRevision  @relation(fields: [maintenancePlanRevisionId], references: [id], onDelete: Restrict)
  item                    Item                     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  assignee                User?                    @relation("WorkOrderAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  checklistItems          WorkOrderChecklistItem[]
  activities              WorkOrderActivity[]

  @@unique([maintenancePlanId, occurrenceKey])
  @@index([projectId, status, scheduledAt])
  @@index([projectId, dueAt])
  @@index([itemId])
  @@index([assigneeId])
  @@map("work_orders")
}

model WorkOrderChecklistItem {
  id                    String    @id @default(cuid())
  workOrderId           String
  sourceChecklistItemId String?
  title                 String
  position              Int
  required              Boolean   @default(false)
  completed             Boolean   @default(false)
  completedAt           DateTime? @db.Timestamptz
  completedById         String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  workOrder           WorkOrder                     @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  sourceChecklistItem MaintenancePlanChecklistItem? @relation(fields: [sourceChecklistItemId], references: [id], onDelete: SetNull)
  completedBy         User?                         @relation("WorkOrderChecklistCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@unique([workOrderId, position])
  @@map("work_order_checklist_items")
}

model MaintenanceGenerationRun {
  id                String                       @id @default(cuid())
  projectId         String
  maintenancePlanId String?
  trigger           MaintenanceGenerationTrigger
  actorId           String?
  windowStart       DateTime                     @db.Timestamptz
  windowEnd         DateTime                     @db.Timestamptz
  status            MaintenanceGenerationStatus  @default(STARTED)
  createdCount      Int                          @default(0)
  skippedCount      Int                          @default(0)
  cancelledCount    Int                          @default(0)
  errorCount        Int                          @default(0)
  details           Json?
  error             String?
  startedAt         DateTime                     @default(now()) @db.Timestamptz
  completedAt       DateTime?                    @db.Timestamptz

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  maintenancePlan MaintenancePlan? @relation(fields: [maintenancePlanId], references: [id], onDelete: SetNull)
  actor           User?            @relation("MaintenanceGenerationRunActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([projectId, startedAt])
  @@index([maintenancePlanId, startedAt])
  @@map("maintenance_generation_runs")
}

model WorkOrderActivity {
  id          String                  @id @default(cuid())
  workOrderId String
  actorId     String?
  action      WorkOrderActivityAction
  metadata    Json?
  createdAt   DateTime                @default(now()) @db.Timestamptz

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  actor     User?     @relation("WorkOrderActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workOrderId, createdAt])
  @@map("work_order_activities")
}

// -------------------------------------------
// Locations (hierarchy)
// -------------------------------------------

model Location {
  id        String   @id @default(cuid())
  projectId String
  parentId  String?
  name      String
  level     Int // 0=Center, 1=Building, 2=Floor, 3=Room, 4=Zone
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent     Location?   @relation("LocationHierarchy", fields: [parentId], references: [id])
  children   Location[]  @relation("LocationHierarchy")
  items      Item[]
  floorPlans FloorPlan[]

  @@index([projectId, parentId])
  @@index([projectId, level])
  @@map("locations")
}

model FloorPlan {
  id         String   @id @default(cuid())
  locationId String
  name       String
  imageUrl   String // StorageDriver path
  width      Int // Original image width
  height     Int // Original image height
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  markers  LocationMarker[]

  @@index([locationId])
  @@map("floor_plans")
}

model LocationMarker {
  id          String   @id @default(cuid())
  floorPlanId String
  itemId      String?
  x           Float // Normalized 0-1 (used when type=POINT)
  y           Float // Normalized 0-1 (used when type=POINT)
  label       String?
  color       String?
  layer       String? // e.g. "safety", "equipment", "hvac", "electrical"
  type        String   @default("POINT") // POINT | POLYGON
  points      Json? // [{x: number, y: number}, ...] for POLYGON, min 3 vertices
  fillColor   String? // hex color, optional alpha
  strokeColor String?
  strokeWidth Float?   @default(2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  floorPlan FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  item      Item?     @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([floorPlanId])
  @@index([itemId])
  @@map("location_markers")
}

// -------------------------------------------
// Document Management
// -------------------------------------------

model Document {
  id               String    @id @default(cuid())
  itemId           String
  name             String
  mimeType         String
  sizeBytes        Int
  expiresAt        DateTime?
  currentVersionId String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  item           Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  currentVersion DocumentVersion?  @relation("DocumentCurrentVersion", fields: [currentVersionId], references: [id])
  versions       DocumentVersion[] @relation("DocumentVersions")

  @@index([itemId])
  @@index([expiresAt])
  @@map("documents")
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  version     Int
  fileName    String
  mimeType    String
  sizeBytes   Int
  storagePath String
  uploadedBy  String
  createdAt   DateTime @default(now())

  document      Document  @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  currentForDoc Document? @relation("DocumentCurrentVersion")
  user          User      @relation(fields: [uploadedBy], references: [id])

  @@unique([documentId, version])
  @@index([documentId])
  @@map("document_versions")
}

// -------------------------------------------
// Alerts & Notifications
// -------------------------------------------

enum AlertType {
  DOCUMENT_EXPIRING
  STATUS_INCIDENT
  STATUS_BLOCKING
  STATUS_FINAL
  EVENT_UPCOMING
}

enum AlertSeverity {
  CRITICAL
  WARNING
  INFO
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  DISMISSED
}

model Alert {
  id             String        @id @default(cuid())
  projectId      String
  alertType      AlertType
  severity       AlertSeverity
  status         AlertStatus   @default(ACTIVE)
  sourceType     String
  sourceId       String
  title          String
  message        String?
  metadata       Json?
  acknowledgedAt DateTime?
  dismissedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, alertType])
  @@index([projectId, status, severity])
  @@index([projectId, createdAt])
  @@map("alerts")
}

model NotificationPreference {
  id        String    @id @default(cuid())
  userId    String
  projectId String
  alertType AlertType
  enabled   Boolean   @default(true)
  email     Boolean   @default(false)
  slack     Boolean   @default(false)
  teams     Boolean   @default(false)
  telegram  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId, alertType])
  @@map("notification_preferences")
}

model UserChannelConfig {
  id          String   @id @default(cuid())
  userId      String
  channelType String
  config      Json
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channelType])
  @@map("user_channel_configs")
}

model NotificationDelivery {
  id           String   @id @default(cuid())
  alertId      String
  userId       String
  channelType  String
  status       String
  errorMessage String?
  deliveredAt  DateTime @default(now())

  @@index([alertId])
  @@index([userId])
  @@index([status])
  @@map("notification_deliveries")
}

model WebhookEndpoint {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  url        String
  secret     String? // HMAC key — excluded from API responses
  eventTypes String[] // ["STATUS_INCIDENT", "DOCUMENT_EXPIRING", ...]
  active     Boolean  @default(true)
  retryCount Int      @default(3)
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("webhook_endpoints")
}

// -------------------------------------------
// Mobile Inspections
// -------------------------------------------

model Inspection {
  id        String   @id @default(cuid())
  itemId    String
  userId    String
  statusId  String?
  notes     String?
  photoPath String?
  createdAt DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([itemId])
  @@index([userId])
  @@map("inspections")
}

// -------------------------------------------
// Events & Calendar
// -------------------------------------------

model Event {
  id          String   @id @default(cuid())
  projectId   String
  itemId      String?
  title       String
  description String?
  startAt     DateTime @db.Timestamptz
  endAt       DateTime @db.Timestamptz
  allDay      Boolean  @default(false)
  rrule       String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  item    Item?   @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([projectId, startAt])
  @@index([projectId, endAt])
  @@index([itemId])
  @@map("events")
}
